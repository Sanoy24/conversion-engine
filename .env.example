# ============================================================
# Conversion Engine — Environment Variables
# Copy this file to .env and fill in your actual values
# ============================================================

# --- LLM (OpenRouter) ---
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Dev tier model (Days 1-4, budget ≤ $4)
DEV_MODEL=deepseek/deepseek-chat-v3-0324
# Eval tier model (Days 5-7, budget ≤ $12)
EVAL_MODEL=anthropic/claude-sonnet-4-20250514

# --- Email (Resend) ---
RESEND_API_KEY=your_resend_api_key_here
RESEND_FROM_EMAIL=outbound@yourdomain.com
RESEND_WEBHOOK_SECRET=your_resend_webhook_secret_here

# --- SMS (Africa's Talking) ---
AT_USERNAME=sandbox
AT_API_KEY=your_africastalking_api_key_here
AT_SHORTCODE=your_sandbox_shortcode_here
AT_ENVIRONMENT=sandbox

# --- CRM (HubSpot) ---
HUBSPOT_ACCESS_TOKEN=your_hubspot_access_token_here
HUBSPOT_PORTAL_ID=your_portal_id_here
USE_HUBSPOT_MCP=false

# --- Calendar (Cal.com) ---
CALCOM_API_KEY=your_calcom_api_key_here
CALCOM_BASE_URL=https://api.cal.com
CALCOM_EVENT_TYPE_ID=1

# --- Observability (Langfuse) ---
LANGFUSE_PUBLIC_KEY=your_langfuse_public_key_here
LANGFUSE_SECRET_KEY=your_langfuse_secret_key_here
LANGFUSE_HOST=https://cloud.langfuse.com
LANGFUSE_BASE_URL=https://cloud.langfuse.com

# --- Application ---
APP_ENV=development
APP_PORT=8000
APP_HOST=0.0.0.0
LOG_LEVEL=INFO

# --- Kill Switch (Data Handling Policy) ---
# When false (default), ALL outbound routes to the staff sink, not real prospects
LIVE_OUTBOUND_ENABLED=false

# --- Seed Data Paths ---
SEEDS_DIR=./tenacious_sales_data/seed
CRUNCHBASE_DATA_PATH=./data/crunchbase_odm_sample.json
LAYOFFS_DATA_PATH=./data/layoffs.csv
JOB_POSTS_SNAPSHOT_PATH=./data/job_posts_snapshot.json
